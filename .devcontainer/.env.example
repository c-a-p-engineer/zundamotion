VOICEVOX_IMAGE=voicevox/voicevox_engine:nvidia-ubuntu24.04-latest
# CPU
# voicevox/voicevox_engine:cpu-ubuntu22.04-latest

# `docker compose --profile runner up render` 用
# ZUNDAMOTION_COMMAND=python -m zundamotion.main scripts/sample.yaml -o output/sample.mp4 --no-cache --hw-encoder cpu --log-kv
